# SafeVision — environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ── required ──────────────────────────────────────────────────────────────────
WANDB_API_KEY=your_wandb_key_here
MODEL_PATH=safevision/runs/safevision/aug-freeze/weights/best.pt

# ── inference ─────────────────────────────────────────────────────────────────
# 0.4 default — false-positive tolerance. Lower for busy floors (more FPs ok),
# raise if operators are dismissing too many alerts.
CONF_THRESHOLD=0.4

# ── storage ───────────────────────────────────────────────────────────────────
DB_PATH=safevision.db
STORE_SNAPS=false    # set to true to store JPEG frame crops in violations table
                     # warning: grows fast — each crop is ~20–50KB

# ── video sources ─────────────────────────────────────────────────────────────
# Comma-separated RTSP URLs or local video file paths for testing
CAMERA_URLS=rtsp://192.168.1.10/stream1,rtsp://192.168.1.11/stream2
# For local testing with a video file:
# CAMERA_URLS=tests/fixtures/sample_floor.mp4
